<UserControl x:Class="NMDSuite.BoneViews.RandLidView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NMDSuite.BoneViews"
             mc:Ignorable="d" 
              d:DesignWidth="800" Height="auto">
    <Grid>
        <Border BorderBrush="White" BorderThickness="1,1,1,1" Grid.Column="0" VerticalAlignment="Top" Margin="4,4,4,0">
            <StackPanel >
                <TextBlock FontWeight="Light" Text="Value:" Foreground="White" Padding="8 8 8 0"/>
                <TextBox FontWeight="Light" x:Name="Rotation_Box" Padding="8 2 8 12" Height="40" TabIndex="0" Width="200" HorizontalAlignment="Left"/>

                <TextBlock FontWeight="Light" Text="Bone Index:" Foreground="White" Padding="8 0 8 0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox FontWeight="Light" x:Name="bone_index_Box" Padding="8 2 8 12" Height="40" TabIndex="1" MinWidth="100"/>
                    
                </StackPanel>





            </StackPanel>

        </Border>
    </Grid>
</UserControl>
