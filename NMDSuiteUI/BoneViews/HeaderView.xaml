<UserControl x:Class="NMDSuite.BoneViews.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NMDSuite.BoneViews"
             mc:Ignorable="d" 
             d:DesignWidth="800" Height="auto">
    <Grid>
        <Border BorderBrush="White" BorderThickness="1,1,1,1" Grid.Column="0" VerticalAlignment="Top" Margin="4,4,4,0">
            <StackPanel >
                <TextBlock FontWeight="Light" Text="Header Values:" Foreground="White" Padding="8 8 8 0"/>
                <TextBox FontWeight="Light" x:Name="Header1_Box" Padding="8 2 8 12" Height="40" TabIndex="0"/>
                <TextBox FontWeight="Light" x:Name="Header2_Box" Padding="8 2 8 12" Height="40" TabIndex="2"/>
                <TextBox FontWeight="Light" x:Name="Header3_Box" Padding="8 2 8 12" Height="40" TabIndex="3"/>
                <TextBox FontWeight="Light" x:Name="Header4_Box" Padding="8 2 8 12" Height="40" TabIndex="4"/>


            </StackPanel>

        </Border>
    </Grid>
</UserControl>
