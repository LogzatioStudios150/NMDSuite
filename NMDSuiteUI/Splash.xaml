<Window x:Class="NMDBase.Splash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NMDSuite" xmlns:wpf="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
        mc:Ignorable="d"
        Title="Splash" Height="450" Width="800" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize">
    <Grid Initialized="Grid_Initialized">

        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF232222"/>
                <GradientStop Color="#FF191818" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        

        <TextBlock x:Name="TitleText" Grid.Column="0" Text="NMDSuite" FontSize="40" Foreground="White" FontWeight="Light" Margin="22,27,493,343"/>
        <Image x:Name="image" Source="/icon_fade.png" Stretch="Fill" Margin="367,0,6,36">
            <Image.OpacityMask>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0.583"/>
                    <GradientStop Color="White" Offset="0"/>
                </LinearGradientBrush>
            </Image.OpacityMask>
        </Image>

        <Border x:Name="UpdatePanel" BorderBrush="Black" Grid.ColumnSpan="2" BorderThickness="1" Background="#FF1E1E1E" Opacity="0.8" Visibility="Collapsed">

            <StackPanel x:Name="Info" Margin="100,83,100,61" Background="#FF232323" Opacity="1">
                <StackPanel.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="20"  Opacity="0.2"/>
                </StackPanel.Effect>
                <TextBlock Name="Info_Title"  Foreground="White" FontSize="28" FontWeight="Light" Background="#FF0D0D0D" Padding="4,0,0,0" Opacity="1"/>
                <Border BorderBrush="#FF595959" Width="auto" Opacity="1" Padding="4" Background="#202020" Height="219" BorderThickness="1,1,1,1" RenderTransformOrigin="0.5,0.5" Margin="4,4,4,2">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <wpf:MarkdownViewer x:Name="Body" Foreground="White"  FontSize="8" FontWeight="Light" Padding="4" Margin="0,0,0,1" HorizontalAlignment="Left" />
                    </ScrollViewer>
                </Border>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <Button x:Name="UpdateConfirm" Style="{StaticResource ModernButton}" Content="Download Update" Width="100" Height="36" HorizontalAlignment="Center" Margin="12,2" Background="#3d3d3d" Foreground="White" FontWeight="Light" TextBlock.TextAlignment="Center" Click="UpdateConfirm_Click"/>
                    <Button x:Name="UpdateSkip" Style="{StaticResource ModernButton}" Content="Update Later" Width="100" Height="36" HorizontalAlignment="Center" Margin="0,0,12,0" Background="#3d3d3d" Foreground="White" FontWeight="Light" TextBlock.TextAlignment="Center" Click="UpdateSkip_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
        <TextBlock x:Name="StatusText" TextAlignment="Right" VerticalAlignment="Bottom" Foreground="White" Margin="0,0,4,0" FontSize="12" FontWeight="Light" Height="16" Text="Status"/>



    </Grid>
</Window>
