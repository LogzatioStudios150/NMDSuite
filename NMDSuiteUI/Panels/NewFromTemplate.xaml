<UserControl x:Class="NMDSuite.Panels.NewFromTemplate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NMDSuite.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Orientation="Vertical">
            <TextBlock Text="New Project from Template" FontSize="20" Foreground="White" Padding="0" Margin="4"/>
            <Separator/>
            <TextBlock Text="Project Name:" Foreground="White" Margin="4"/>
            <TextBox x:Name ="NameBox" Width="500" FontSize="14" HorizontalAlignment="Left"/>
            <TextBlock Text="Template:" Foreground="White" Margin="4"/>
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="NMDBox" Width="500" FontSize="14" Margin="8 4"/>
                <Button x:Name="NMDBtn" Style="{StaticResource ModernButton}" Background="#3d3d3d"  Content="Browse" VerticalAlignment="Center" HorizontalAlignment="Center" Width="80" Height="30" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
